@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/FFmpegPkgConfigTargets.cmake")

if(NOT FFmpeg_ROOT)
    set(FFmpeg_ROOT "${PACKAGE_PREFIX_DIR}")
endif()

if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/FFmpegNativeTargets.cmake")
    if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/FFmpegNativeDependencies.cmake")
        include("${CMAKE_CURRENT_LIST_DIR}/FFmpegNativeDependencies.cmake")
    endif()
    include("${CMAKE_CURRENT_LIST_DIR}/FFmpegNativeTargets.cmake")

    if(NOT TARGET FFmpeg::FFmpeg)
        add_library(FFmpeg::FFmpeg INTERFACE IMPORTED)
        set(_FFmpeg_native_link)
        foreach(_FFmpeg_native_component IN ITEMS avdevice avfilter avformat avcodec swresample swscale avutil)
            if(TARGET FFmpeg::${_FFmpeg_native_component})
                list(APPEND _FFmpeg_native_link FFmpeg::${_FFmpeg_native_component})
                set(FFmpeg_${_FFmpeg_native_component}_FOUND TRUE)
            endif()
        endforeach()
        set_property(TARGET FFmpeg::FFmpeg PROPERTY INTERFACE_LINK_LIBRARIES "${_FFmpeg_native_link}")
    endif()
    foreach(_FFmpeg_native_target IN ITEMS FFmpeg avdevice avfilter avformat avcodec swresample swscale avutil)
        if(TARGET FFmpeg::${_FFmpeg_native_target})
            set_target_properties(FFmpeg::${_FFmpeg_native_target} PROPERTIES FOLDER "FFmpeg/Imported")
        endif()
    endforeach()

    set(FFmpeg_FOUND TRUE)
    check_required_components(FFmpeg)
    return()
endif()

set(_FFmpeg_components ${FFmpeg_FIND_COMPONENTS})
if(NOT _FFmpeg_components)
    set(_FFmpeg_components avutil swresample swscale avcodec avformat avfilter avdevice)
endif()

set(_FFmpeg_required)
if(FFmpeg_FIND_REQUIRED)
    list(APPEND _FFmpeg_required REQUIRED)
endif()

set(_FFmpeg_static)
if(FFmpeg_USE_STATIC_LIBS OR FFMPEG_USE_STATIC_LIBS)
    list(APPEND _FFmpeg_static STATIC)
endif()

ffmpeg_pkg_config_import_targets(
    GLOBAL
    ${_FFmpeg_required}
    ${_FFmpeg_static}
    NAMESPACE FFmpeg::
    ROOT "${PACKAGE_PREFIX_DIR}"
    COMPONENTS ${_FFmpeg_components})

check_required_components(FFmpeg)
